{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default app capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-title",
    "core:event:default",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "notification:default",
    "store:default",
    "dialog:default"
  ]
}
