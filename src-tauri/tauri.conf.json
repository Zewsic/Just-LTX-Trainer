{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Just LTX Trainer",
  "version": "0.1.1",
  "identifier": "app.justltx.trainer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Just LTX Trainer",
        "width": 1100,
        "height": 720,
        "minWidth": 1100,
        "maxWidth": 1100,
        "minHeight": 560,
        "resizable": true,
        "maximizable": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
