yarn.lock
bun.lockb

# ───────────────── Rust / Tauri ─────────────────
src-tauri/target
# `gen/schemas` пересоздаются на сборке — коммитить не нужно.
src-tauri/gen

# Cargo.lock КОММИТИМ — это бинарный проект, нужна воспроизводимость.

# ───────────────── secrets / env ─────────────────
.env
.env.*
!.env.example

# Tauri signing / notarization
*.p12
*.pem
.tauri-private-key
.tauri-private-key.pub

# ───────────────── editors / IDE ─────────────────
.idea
.vscode/*
